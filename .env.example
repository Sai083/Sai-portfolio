# Bhukya Sai Portfolio - Environment Configurations

# Admin Password for the Recruiter Dashboard
ADMIN_PASSWORD=admin123

# Optional: OpenAI API Key for the RAG AI Assistant
# If left empty, the chatbot will fall back to a custom local TF-IDF semantic search
# OPENAI_API_KEY=your-openai-api-key-here

# Production Database Configurations (Railway MySQL)
# DATABASE_URL=mysql://user:password@host:port/database
# Or configure explicitly:
# MYSQL_HOST=your-mysql-host
# MYSQL_USER=your-mysql-user
# MYSQL_PASSWORD=your-mysql-password
# MYSQL_DATABASE=your-mysql-database
# MYSQL_PORT=3306

# SMTP Email Notification Configurations (Gmail SMTP)
# SMTP_USER=your-sender-gmail-address@gmail.com
# SMTP_PASSWORD=your-gmail-app-password (use an App Password, not your account password)
# NOTIFICATION_EMAIL=bhukyasai003@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
